[0.033414, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.033967, "o", "\u001b[1mfrag\u001b[0m  \u001b[90m— chunk-level diff for RAG corpora\u001b[0m\r\n\r\n\u001b[90m# Web pages drift. Re-embedding the whole corpus on every sync wastes credits.\u001b[0m\r\n\u001b[90m# frag detects what actually changed at the chunk level.\u001b[0m\r\n"]
[2.540611, "o", "\r\n"]
[2.54094, "o", "\u001b[90m# we synced this URL earlier — 32 chunks already embedded\u001b[0m\r\n"]
[3.05366, "o", "\u001b[32m$\u001b[0m \u001b[36mls .frag-state.json .rag-store.pkl\u001b[0m\r\n"]
[3.493466, "o", ".frag-state.json\t.rag-store.pkl\r\n"]
[5.009599, "o", "\r\n\u001b[90m# ── sync again: see what's actually changed ──\u001b[0m\r\n"]
